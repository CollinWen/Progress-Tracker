# Production Environment Configuration

ENVIRONMENT=production

# Firebase Configuration
FIREBASE_PROJECT_ID=momentum-prod
FIREBASE_CREDENTIALS_PATH=./serviceAccountKey-prod.json
# Or use JSON directly (for deployment platforms like Railway/Heroku):
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# CORS Origins (comma-separated) - IMPORTANT: Only add trusted domains
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# API Configuration
DEBUG=false
