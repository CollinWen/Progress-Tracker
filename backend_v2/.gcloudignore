# This file specifies files that are *not* uploaded to Google Cloud
# using gcloud. It follows the same syntax as .gitignore

.gcloudignore
.git
.gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
*.egg-info/

# Environment files (these should be set via gcloud run services update)
.env
.env.local
*.pem
serviceAccountKey.json

# IDE
.vscode/
.idea/
*.swp
*.swo

# Documentation
README.md
DEPLOYMENT.md
.env.example

# Testing
.pytest_cache/
.coverage
htmlcov/

# OS
.DS_Store
Thumbs.db
