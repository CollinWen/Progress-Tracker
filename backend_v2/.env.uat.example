# UAT Environment Configuration

ENVIRONMENT=uat

# Firebase Configuration
FIREBASE_PROJECT_ID=momentum-uat
FIREBASE_CREDENTIALS_PATH=./serviceAccountKey-uat.json
# Or use JSON directly (for deployment platforms like Railway/Heroku):
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=https://uat.yourdomain.com,http://localhost:3000,http://localhost:5173

# API Configuration
DEBUG=true
