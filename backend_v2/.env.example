# Environment Configuration
ENVIRONMENT=development

# Firebase Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_DATABASE_NAME=(default)
FIREBASE_CREDENTIALS_PATH=/path/to/serviceAccountKey.json

# API Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
DEBUG=true

# Optional: JWT Configuration (if using custom tokens)
JWT_SECRET=your-secret-key-change-in-production

# Agent MCP auth — the /mcp endpoint is gated by per-user API keys.
# Users generate keys via POST /api/keys (requires a Firebase ID token).
# Agents pass the key as: Authorization: Bearer mom_<key>
# No backend config is needed — keys are stored (hashed) in Firestore.
