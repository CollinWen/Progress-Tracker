# Environment Configuration
ENVIRONMENT=development

# Firebase Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_DATABASE_NAME=(default)
FIREBASE_CREDENTIALS_PATH=/path/to/serviceAccountKey.json

# API Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
DEBUG=true

# Optional: JWT Configuration (if using custom tokens)
JWT_SECRET=your-secret-key-change-in-production

# Agent orchestrator (MCP) auth — gates the /mcp endpoint mounted alongside the API.
# ORCHESTRATOR_TOKEN: shared bearer token the local orchestrator must send.
#   Generate once: python -c "import secrets; print(secrets.token_urlsafe(32))"
#   In production, store via Secret Manager rather than a plaintext .env.
# ORCHESTRATOR_USER_ID: the Firebase UID the orchestrator acts as.
ORCHESTRATOR_TOKEN=
ORCHESTRATOR_USER_ID=
